{
  "$schema": "https://biomejs.dev/schemas/2.0.5/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 200
  },
  "linter": {
    "enabled": true,
    "rules": {
      "performance": {
        "noImgElement": "off"
      },
      "security": {
        "noBlankTarget": "off"
      },
      "style": {
        "useImportType": "off"
      }
    }
  }
}
